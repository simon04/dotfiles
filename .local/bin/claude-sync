#!/usr/bin/env python3
# claude-sync <other-host> — two-way sync of Claude Code sessions over ssh+tar.
# Each session is an append-only <uuid>.jsonl file, so --keep-newer-files gives
# a safe newest-wins union merge: nothing is deleted, newer copies win.
import subprocess, sys

host = sys.argv[1]

# Pull: remote sessions in, keeping any locally-newer file.
subprocess.run(f"ssh {host} 'tar --create --zstd --directory $HOME/.claude projects' | tar --extract --zstd --keep-newer-files --directory $HOME/.claude", shell=True)

# Push: our sessions out, keeping any remotely-newer file.
subprocess.run(f"tar --create --zstd --directory $HOME/.claude projects | ssh {host} 'tar --extract --zstd --keep-newer-files --directory $HOME/.claude'", shell=True)

print(f"claude-sync: synced ~/.claude/projects with {host}")
